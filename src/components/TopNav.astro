---
// Top nav is deliberately kept to 5 items — primary surfaces only.
// Secondary pages (Uses, Resume, Disclosures, Contact) live in the footer.
const navItems = [
  { label: 'Writing', href: '/writing' },
  { label: 'Projects', href: '/projects' },
  { label: 'Talks', href: '/talks' },
  { label: 'About', href: '/about' },
];
---

<div class="container">
  <nav class="top">
    <div class="row">
      <a href="/" class="brand">Bill <em>Easton</em></a>
      <ul>
        {navItems.map(({ label, href }) => (
          <li><a href={href}>{label}</a></li>
        ))}
      </ul>
    </div>
  </nav>
</div>

<style>
  nav.top {
    padding: 32px 0;
    border-bottom: 1px solid var(--rule);
    margin-bottom: 40px;
  }
  nav.top .row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-size: 14px;
    flex-wrap: wrap;
    gap: 16px;
  }
  nav.top .brand {
    font-family: var(--font-display);
    font-size: 22px;
    letter-spacing: -0.01em;
    color: var(--ink);
    text-decoration: none;
  }
  nav.top .brand em {
    font-style: italic;
    color: var(--accent);
  }
  nav.top ul {
    list-style: none;
    display: flex;
    gap: 28px;
    margin: 0;
    padding: 0;
  }
  nav.top a {
    color: var(--ink-soft);
    text-decoration: none;
    transition: color 0.15s;
  }
  nav.top a:hover {
    color: var(--accent);
  }
  @media (max-width: 820px) {
    nav.top ul {
      gap: 22px;
    }
  }
  @media (max-width: 680px) {
    nav.top ul {
      gap: 16px;
      font-size: 13px;
    }
  }
</style>
