---
// Footer — edit contact links and colophon here.
// Secondary navigation lives here to keep the top nav tight.
---

<div class="container">
  <footer id="contact">
    <div class="row">
      <div class="col">
        <div class="tag">Contact</div>
        <a href="https://linkedin.com/in/williamseaston">LinkedIn</a>
        &nbsp; · &nbsp;
        <a href="https://github.com/strawgate">GitHub</a>
        &nbsp; · &nbsp;
        <a href="mailto:bill@strawgate.com">Email</a>
        &nbsp; · &nbsp;
        <a href="/rss.xml">RSS</a>
      </div>
      <div class="col">
        <div class="tag">More</div>
        <a href="/uses">Uses</a>
        &nbsp; · &nbsp;
        <a href="/resume">Resume</a>
        &nbsp; · &nbsp;
        <a href="/disclosures">Disclosures</a>
      </div>
      <div class="col colophon">
        <div class="tag">Colophon</div>
        Markdown-powered, built with Astro.<br />
        <span class="subtle">Set in Instrument Serif &amp; Inter.</span>
      </div>
    </div>
  </footer>
</div>

<style>
  footer {
    padding: 80px 0 60px;
    margin-top: 60px;
    border-top: 1px solid var(--rule);
    font-size: 14px;
    color: var(--ink-muted);
  }
  footer .row {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 32px;
  }
  footer .colophon {
    text-align: right;
  }
  footer a {
    color: var(--ink-soft);
    text-decoration: none;
    border-bottom: 1px solid var(--rule);
    transition: all 0.15s;
    padding-bottom: 1px;
  }
  footer a:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }
  footer .tag {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 12px;
  }
  footer .subtle {
    color: var(--ink-muted);
  }
  @media (max-width: 820px) {
    footer .row {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    footer .colophon {
      text-align: left;
    }
  }
</style>
