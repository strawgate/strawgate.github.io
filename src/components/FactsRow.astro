---
import { stats, formatCount, freshnessLabel, getTotalStarsAll, getPyPITotalMonthly, starHistory, STAR_HISTORY_MIN_POINTS } from '../data/stats';
import Sparkline from './Sparkline.astro';

// FactsRow — credential-compressing stats, mix of static and live.
// To edit: change the objects below. Values with `live: true` are pulled at build time.

// "Lifetime merged OSS PRs" trends up monotonically and updates daily.
// Total stars = all repos across the account (not just tracked list).
const facts = [
  {
    num: '$200M',
    label: 'Exit as Verve CTO (Rockwell Automation, 2022)',
    live: false,
  },
  {
    num: formatCount(stats.pypi['py-key-value-aio']?.last_day),
    label: 'Daily Downloads of py-key-value',
    live: true,
  },
  {
    num: '1 of 2',
    label: 'Core FastMCP Maintainers',
    live: false,
  },
  {
    num: `${formatCount(stats.prs.all_time)}+`,
    label: 'Lifetime Merged OSS PRs',
    live: true,
  },
];

const totalStars = getTotalStarsAll();
const pypiMonthly = getPyPITotalMonthly();
const showFreshness = facts.some((f) => f.live);
const showSparkline = starHistory.length >= STAR_HISTORY_MIN_POINTS;
---

<div class="facts">
  {facts.map((f) => (
    <div class="fact">
      <span class="num">{f.num}</span>
      <span class="label">
        {f.label}
        {f.live && <span class="live-dot" title="Refreshed at build time"></span>}
      </span>
    </div>
  ))}
  <div class="fact fact-star">
    {showSparkline && (
      <div class="sparkline-wrap">
        <Sparkline data={starHistory} height={28} />
      </div>
    )}
    <span class="num">{formatCount(totalStars)}</span>
    <span class="label">
      GitHub Stars (all repos)
      <span class="live-dot" title="Refreshed nightly"></span>
    </span>
  </div>
</div>

{showFreshness && (
  <p class="freshness">
    Live figures refreshed <time datetime={stats.generated_at}>{freshnessLabel()}</time>.
    {pypiMonthly > 0 && ` · ${formatCount(pypiMonthly)} PyPI downloads/month`}
  </p>
)}

<style>
  .facts {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 24px;
    padding: 32px 0;
    margin-top: 40px;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }
  .facts .fact {
    font-size: 13px;
  }
  .facts .fact .num {
    font-family: var(--font-display);
    font-size: 40px;
    font-weight: 400;
    color: var(--ink);
    display: block;
    line-height: 1;
    margin-bottom: 8px;
    letter-spacing: -0.02em;
  }
  .facts .fact .label {
    color: var(--ink-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 11px;
    line-height: 1.4;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .fact-star {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .sparkline-wrap {
    margin-bottom: 8px;
    height: 28px;
  }
  .live-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0.75;
    flex-shrink: 0;
  }
  .freshness {
    margin-top: 14px;
    font-size: 11px;
    color: var(--ink-muted);
    text-align: right;
    font-family: var(--font-mono);
    letter-spacing: 0.04em;
  }
  @media (max-width: 900px) {
    .facts {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px 24px;
    }
    .fact-star {
      grid-column: span 2;
    }
  }
  @media (max-width: 480px) {
    .facts {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
