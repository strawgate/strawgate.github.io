---
import { getCollection } from 'astro:content';

export interface Props {
  limit?: number;
}

const { limit } = Astro.props;

const allPosts = (await getCollection('posts'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const posts = limit ? allPosts.slice(0, limit) : allPosts;

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'UTC',
  });
---

<ul class="writing-list">
  {posts.map((post) => (
    <li>
      <a href={`/writing/${post.id}`} class="post">
        <div class="meta-row">
          <span>{fmt(post.data.pubDate)}</span>
          {post.data.tags.length > 0 && (
            <span class="tag">{post.data.tags.join(' · ')}</span>
          )}
        </div>
        <h3>{post.data.title}</h3>
        <p class="dek">{post.data.description}</p>
      </a>
    </li>
  ))}
  {posts.length === 0 && (
    <li class="empty">
      <p>No posts yet. First one is in the oven.</p>
    </li>
  )}
</ul>

<style>
  .writing-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .writing-list li {
    padding: 24px 0;
    border-bottom: 1px solid var(--rule);
  }
  .writing-list li:last-child {
    border-bottom: none;
  }
  .writing-list a.post {
    text-decoration: none;
    color: inherit;
    display: block;
    transition: transform 0.15s;
  }
  .writing-list a.post:hover :global(h3) {
    color: var(--accent);
  }
  .writing-list h3 {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 400;
    line-height: 1.25;
    letter-spacing: -0.01em;
    margin-bottom: 10px;
    transition: color 0.15s;
  }
  .writing-list .meta-row {
    display: flex;
    gap: 16px;
    font-size: 13px;
    color: var(--ink-muted);
    margin-bottom: 8px;
    font-feature-settings: 'tnum';
  }
  .writing-list .meta-row .tag {
    color: var(--accent);
    font-weight: 500;
  }
  .writing-list .dek {
    font-size: 15px;
    color: var(--ink-soft);
    line-height: 1.55;
    margin: 0;
  }
  .writing-list .empty {
    color: var(--ink-muted);
    font-style: italic;
  }
</style>
