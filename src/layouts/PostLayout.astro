---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
}

const { title, description, pubDate, updatedDate, tags = [] } = Astro.props;

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'UTC',
  });
---

<BaseLayout title={`${title} — Bill Easton`} description={description}>
  <article class="container">
    <header class="post-header">
      <div class="meta-row">
        <time datetime={pubDate.toISOString()}>{fmt(pubDate)}</time>
        {tags.length > 0 && <span class="tag">{tags.join(' · ')}</span>}
      </div>
      <h1>{title}</h1>
      <p class="dek">{description}</p>
    </header>

    <div class="prose">
      <slot />
    </div>

    {updatedDate && (
      <p class="updated">
        Last updated <time datetime={updatedDate.toISOString()}>{fmt(updatedDate)}</time>.
      </p>
    )}

    <nav class="post-footer">
      <a href="/writing">← All writing</a>
      <a href="/">Home →</a>
    </nav>
  </article>
</BaseLayout>

<style>
  .post-header {
    padding: 40px 0 48px;
    border-bottom: 1px solid var(--rule);
    margin-bottom: 48px;
  }
  .meta-row {
    display: flex;
    gap: 16px;
    font-size: 13px;
    color: var(--ink-muted);
    margin-bottom: 16px;
    font-feature-settings: 'tnum';
  }
  .meta-row .tag {
    color: var(--accent);
    font-weight: 500;
  }
  .post-header h1 {
    font-family: var(--font-display);
    font-size: clamp(38px, 5vw, 56px);
    line-height: 1.08;
    letter-spacing: -0.015em;
    font-weight: 400;
    color: var(--ink);
    margin-bottom: 20px;
  }
  .post-header .dek {
    font-size: 20px;
    line-height: 1.5;
    color: var(--ink-soft);
    max-width: 620px;
  }
  .updated {
    margin-top: 48px;
    font-size: 13px;
    color: var(--ink-muted);
  }
  .post-footer {
    margin-top: 60px;
    padding-top: 24px;
    border-top: 1px solid var(--rule);
    display: flex;
    justify-content: space-between;
    font-size: 14px;
    color: var(--ink-soft);
  }
  .post-footer a {
    text-decoration: none;
    transition: color 0.15s;
  }
  .post-footer a:hover {
    color: var(--accent);
  }
</style>
